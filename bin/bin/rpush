#!/usr/bin/env bash

function missingfile {
    echo "No .rclonepath file in current directory"
    exit 1
}

function run {
    [ -f '.rclonepath' ] || missingfile
    remote=$(cat '.rclonepath')
    rclone sync \
        --filter-from="$XDG_CONFIG_HOME"/rclone/filter-file.txt \
        "$PWD" "$remote"
}

function rpushdir {
    cd "$1" || exit 3
    run
    echo "${PWD}" "Pushed"
    cd - >/dev/null || exit 3
}

if [ $# == 0 ]; then
    run
elif [[ $1 == "--all" ]] || [[ $1 == "-a" ]]; then
    export -f rpushdir
    export -f run
    export -f missingfile

    fd -H \.rclonepath$ ~ -j8 --exec bash -c 'rpushdir "$1"' _ "{//}"
else
    echo "rpull takes no arguments or -a/--all."
    exit 2
fi
