#!/usr/bin/env bash

function missingfile {
    echo "No .rclonepath file in current directory"
    exit 1
}

function run {
    [ -f '.rclonepath' ] || missingfile

    IFS= read -r remote <'.rclonepath'
    rclone sync \
        --filter-from="$XDG_CONFIG_HOME"/rclone/filter-file.txt \
        "$remote" "$PWD"
}

function rpulldir {
    cd "$1" || exit 3
    rpull
    echo "${PWD}" "Pulled"
    cd - >/dev/null || exit 3
}

if [ $# == 0 ]; then
    run
elif [[ $1 == "--all" ]] || [[ $1 == "-a" ]]; then
    export -f missingfile
    export -f run
    export -f rpulldir

    fd -H \.rclonepath ~ -j8 --exec bash -c 'rpulldir "$1"' _ "{//}"
else
    echo "rpull takes no arguments or -a/--all."
    exit 2
fi
